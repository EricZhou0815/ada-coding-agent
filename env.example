# Copy this file to .env and fill in your keys
# Then load it before running: source .env  (or use 'direnv' / dotenv loader)

# ── LLM Provider ────────────────────────────────────────────────────────────
# Ada auto-detects your provider based on which API key is present.
# Priority: GROQ > OPENAI > mock (if neither key is set)
# You can force a provider by setting LLM_PROVIDER explicitly:
#   LLM_PROVIDER=groq | openai | mock
LLM_PROVIDER=

# You can optionally specify a particular model:
# LLM_MODEL=llama-3.3-70b-versatile

# --- Groq (default, recommended — fast & generous free tier) ---
# Get a free key at: https://console.groq.com/keys
#
# Single key (simple):
GROQ_API_KEY=your_groq_api_key_here
#
# Multiple keys for automatic rotation (recommended for production):
# If one key hits rate limits or quota, Ada automatically switches to the next.
# Comma-separated, no spaces:
# GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3

# --- OpenAI (optional fallback) ---
#
# Single key:
OPENAI_API_KEY=your_openai_api_key_here
#
# Multiple keys for automatic rotation:
# OPENAI_API_KEYS=sk_key1,sk_key2,sk_key3

# --- Context Management ---
# Maximum tokens to keep in LLM conversation history (prevents OOM and API errors)
# Default: 80000 (safe for GPT-4/Claude/Llama-3.3-70B)
# Lower if you hit memory issues, raise if you need more context
# ADA_MAX_CONTEXT_TOKENS=80000

# ── GitHub Integration (required for run_sdlc.py) ───────────────────────────
# Ada uses this token to push branches and open Pull Requests on your behalf.
#
# How to get one:
#   1. Go to https://github.com/settings/tokens
#   2. Click "Generate new token (classic)"
#   3. Set a note (e.g. "Ada AI Agent") and expiration
#   4. Check the "repo" scope (full control of repositories)
#   5. Click "Generate token" and copy the value (shown only once!)
#
# Required scopes: repo
GITHUB_TOKEN=ghp_your_personal_access_token_here

# ── Webhook Security (required for production) ─────────────────────────────
# HMAC secret to verify GitHub webhook payloads are authentic.
# 
# How to set up:
#   1. Generate a random secret: openssl rand -hex 32
#   2. Add it here AND in your GitHub repo's webhook settings
#      (Settings → Webhooks → Edit → Secret)
#   3. GitHub will sign payloads with this secret, Ada verifies them
#
# If not set, webhook signature verification is DISABLED (insecure!)
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ── Redis Configuration ─────────────────────────────────────────────────────
# Redis is used for:
#   1. Webhook idempotency (prevents duplicate GitHub webhook processing)
#   2. Real-time log streaming (SSE endpoint for UI updates)
#   3. Background task queuing (Celery broker)
#
# Local development (default):
REDIS_URL=redis://localhost:6379/0
#
# Docker Compose (if using docker-compose.yml):
# REDIS_URL=redis://redis:6379/0
#
# Production examples:
# Redis Cloud: REDIS_URL=redis://default:password@redis-12345.c1.us-east-1.cloud.redislabs.com:12345
# AWS ElastiCache: REDIS_URL=redis://my-cluster.abc123.cache.amazonaws.com:6379
# Azure Cache: REDIS_URL=redis://:password@myapp.redis.cache.windows.net:6380?ssl=true
#
# Note: Ada degrades gracefully if Redis is unavailable (logs warning, continues processing)

# ── VCS Platform Selection ──────────────────────────────────────────────────
# Ada supports multiple VCS platforms. Set this to switch between them.
# Default: github
#
# Options:
#   VCS_PLATFORM=github   (default - uses GITHUB_TOKEN)
#   VCS_PLATFORM=gitlab   (uses GITLAB_TOKEN + optional GITLAB_URL)
VCS_PLATFORM=github

# ── GitLab Integration (alternative to GitHub) ──────────────────────────────
# If using GitLab, set these instead of GITHUB_TOKEN.
#
# How to get a GitLab token:
#   1. Go to https://gitlab.com/-/profile/personal_access_tokens
#      (or your self-hosted instance's equivalent)
#   2. Create a token with "api" scope
#
# Required scopes: api
# GITLAB_TOKEN=glpat_your_personal_access_token_here

# For self-hosted GitLab instances (default: https://gitlab.com):
# GITLAB_URL=https://gitlab.example.com

# GitLab webhook secret (same concept as GitHub):
# GITLAB_WEBHOOK_SECRET=your_gitlab_webhook_secret_here

# ── Application Version ─────────────────────────────────────────────────────
# Semantic version for documentation and monitoring (MAJOR.MINOR.PATCH)
# Note: API routes stay at /api/v1/ regardless of this version
APP_VERSION=1.0.0

# ── API Authentication ──────────────────────────────────────────────────────
# API keys for authenticating requests to Ada's execution endpoints.
# CRITICAL: Set this in production to prevent unauthorized job submissions!
#
# Format: Comma-separated list of API keys (no spaces)
# Example: API_KEYS=ada-prod-key-abc123,ada-ui-key-xyz789,ada-ci-key-def456
#
# How to use:
#   Clients must send API key in X-Api-Key header:
#   curl -X POST http://localhost:8000/api/v1/execute \
#     -H "X-Api-Key: ada-prod-key-abc123" \
#     -H "Content-Type: application/json" \
#     -d '{...}'
#
# Generate secure keys with: openssl rand -hex 32
#
# WARNING: If not set, API authentication is DISABLED (dev mode only!)
API_KEYS=

# ── Ada Management Scope ────────────────────────────────────────────────────
# Control which PRs and CI pipelines Ada should handle automatically.
# By default, Ada only manages branches/PRs she creates with the ada-ai/ prefix.

# Branch prefix for Ada-managed branches (default: "ada-ai/")
# Ada creates branches like: ada-ai/STORY-123-feature-name
# Only branches with this prefix will trigger auto-fixes and responses
ADA_BRANCH_PREFIX=ada-ai/

# Allow Ada to respond to @ada-ai mentions on ANY PR (default: false)
# If false, @ada-ai only works on Ada's own branches (safer)
# If true, team members can use @ada-ai on human-created PRs too
ADA_HANDLE_ALL_PRS=false

# Auto-fix CI failures on ALL branches (default: false)  
# If false, only auto-fixes CI on Ada's branches (recommended)
# If true, Ada will attempt to fix CI failures on any branch (risky!)
ADA_AUTO_FIX_CI_ALL=false

# ── Command Execution Security ──────────────────────────────────────────────
# Ada uses an allowlist to prevent shell command injection attacks.
# Default allowed commands: python, pip, pytest, npm, node, git, eslint, ruff, black
#
# Add project-specific commands here (comma-separated, no spaces):
# Example: ADA_CUSTOM_COMMANDS=cargo,go,mvn,gradle,make,tsc,jest
#
# WARNING: Only add commands you trust! Each command can execute with Ada's permissions.
# Never add: rm, curl, wget, bash, sh, eval, or other potentially dangerous commands.
ADA_CUSTOM_COMMANDS=